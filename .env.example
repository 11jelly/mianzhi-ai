APP_ENV=development

DATABASE_URL=mysql+asyncmy://ai_interview_user:CHANGE_ME@127.0.0.1:3306/ai_interview

JWT_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120

LLM_API_KEY=
LLM_MODEL=qwen-plus
LLM_BASE_URL=https://YOUR_WORKSPACE_ID.cn-beijing.maas.aliyuncs.com/compatible-mode/v1

ASR_API_KEY=
ASR_MODEL=qwen3-asr-flash
ASR_MAX_DURATION_SECONDS=300
ASR_MAX_FILE_SIZE_MB=10

MAX_FOLLOW_UPS_PER_SESSION=2
MAX_FOLLOW_UPS_PER_PRIMARY=1
FOLLOW_UP_MIN_SCORE=20
FOLLOW_UP_SCORE_THRESHOLD=65

EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSION=1024
RAG_TOP_K=4
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=80
RAG_MAX_DOCUMENT_SIZE_MB=5